{
  "name": "asa1984.dev",
  "description": "asa1984's personal website",
  "private": true,
  "type": "module",
  "scripts": {
    "gen": "turbo run gen && biome check --write",
    "lint": "biome check",
    "format": "biome check --write",
    "typecheck": "turbo run typecheck",
    "dev": "dotenvx run -- turbo run dev",
    "build": "dotenvx run -- turbo run build",
    "start": "dotenvx run -- turbo run start",
    "migrate:dev": "dotenvx run -- turbo run migrate:dev",
    "migrate:prod": "dotenvx run -- turbo run migrate:prod",
    "deploy": "dotenvx run -- turbo run deploy",
    "deploy:secret": "dotenvx run -- turbo run deploy:secret",
    "staging": "dotenvx run -- turbo run staging",
    "staging:secret": "dotenvx run -- turbo run staging:secret",
    "build:frontend": "dotenvx run -- pnpm run --filter=frontend build:prod",
    "deploy:frontend": "dotenvx run -- pnpm run --filter=frontend deploy:prod"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@dotenvx/dotenvx": "1.26.0",
    "turbo": "2.3.3",
    "wrangler": "catalog:"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": ">=5.0.1",
      "brace-expansion@^1.0.0": ">=1.1.12",
      "brace-expansion@^2.0.0": ">=2.0.3",
      "diff": ">=5.2.2",
      "esbuild": ">=0.25.0",
      "immutable": ">=4.3.8",
      "js-yaml@^3.0.0": ">=3.14.2",
      "js-yaml@^4.0.0": ">=4.1.1",
      "minimatch@^7.0.0": ">=7.4.8",
      "minimatch@^10.0.0": ">=10.2.3",
      "nanoid@^3.0.0": ">=3.3.12",
      "picomatch@^2.0.0": ">=2.3.2",
      "picomatch@^4.0.0": ">=4.0.4",
      "postcss": ">=8.5.14",
      "tar-fs@^2.0.0": ">=2.1.4"
    }
  }
}
